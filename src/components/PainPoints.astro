---
import Button from './Button.astro';
const points = [
  {
    pain: 'устала от найма',
    result: 'перестанешь зависеть от начальника и будешь работать 4–5 часов из любой точки мира, как мои ученики',
  },
  {
    pain: 'хочешь творческую профессию',
    result: 'превратишь любовь к красивым видео в профессию с доходом от 100к ₽',
  },
  {
    pain: 'боишься и не знаешь, как начать',
    result: 'пройдёшь путь по моей системе и сможешь получить первых клиентов ещё на курсе',
  },
  {
    pain: 'нет системы',
    result: '8 модулей и 31 урок — от настроек камеры до продаж и продюсирования',
  },
  {
    pain: 'низкий чек',
    result: 'научишься упаковывать офферы, отрабатывать возражения и поднимешь чек',
  },
  {
    pain: 'нет клиентов',
    result: 'получишь 3 рабочие схемы поиска клиентов + воркшоп по продажам с 20+ заявками в реальном времени',
  },
  {
    pain: 'блог не работает',
    result: 'упакуешь свой блог и начнёшь делать рилсы, которые приводят клиентов',
  },
  {
    pain: 'хочешь стать уверенным в себе профессионалом',
    result: 'соберёшь сильное портфолио из 5+ съёмок и поймёшь, как выделиться среди остальных',
  },
];
---

<section class="pp section">
  <div class="container">
    <p class="h-eyebrow reveal">для кого этот курс</p>
    <h2 class="h-1 reveal">
      ты сейчас здесь, <span class="underline-pink">если…</span>
    </h2>

    <ul class="pp__list">
      {points.map((p, i) => (
        <li class="pp__item reveal" style={`transition-delay: ${i * 60}ms`}>
          <details class="pp__details">
            <summary class="pp__summary">
              <span class="pp__index">{String(i + 1).padStart(2, '0')}</span>
              <span class="pp__text">{p.pain}</span>
              <span class="pp__chevron" aria-hidden="true">+</span>
            </summary>
            <p class="pp__result">{p.result}</p>
          </details>
        </li>
      ))}
    </ul>

    <div class="pp__cta reveal">
      <Button href="#pricing" variant="bracket" external={false}>всё про меня, хочу на курс!</Button>
    </div>
  </div>
</section>

<style>
  .pp .h-1 {
    margin-top: 12px;
    margin-bottom: 64px;
    max-width: 14ch;
  }
  .pp__list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--ink);
  }
  .pp__item {
    border-bottom: 1px solid var(--line);
    transition: background 0.3s ease;
    display: flex;
  }
  .pp__item:nth-child(odd) {
    border-right: 1px solid var(--line);
  }
  .pp__item:hover {
    background: var(--pink-soft);
  }
  .pp__details {
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .pp__details[open] {
    justify-content: flex-start;
  }
  .pp__summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    gap: 24px;
    align-items: baseline;
    padding: 28px 12px;
  }
  .pp__summary::-webkit-details-marker {
    display: none;
  }
  .pp__index {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-soft);
    letter-spacing: 0;
    flex-shrink: 0;
  }
  .pp__text {
    font-size: clamp(20px, 1.9vw, 28px);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.02em;
    flex: 1;
  }
  .pp__chevron {
    font-size: 24px;
    font-weight: 300;
    line-height: 1;
    color: var(--ink-soft);
    transition: transform 0.25s ease, color 0.25s ease;
    flex-shrink: 0;
  }
  .pp__details[open] .pp__chevron {
    transform: rotate(45deg);
    color: var(--pink-deep);
  }
  .pp__result {
    font-size: 15px;
    line-height: 1.5;
    color: var(--ink-soft);
    padding: 0 12px 24px 56px;
    max-width: 50ch;
  }
  .pp__cta {
    margin-top: 48px;
    display: flex;
    justify-content: flex-start;
  }
  @media (max-width: 720px) {
    .pp__list {
      grid-template-columns: 1fr;
    }
    .pp__item:nth-child(odd) {
      border-right: none;
    }
    .pp__summary {
      padding: 22px 8px;
      gap: 16px;
    }
    .pp__result {
      padding: 0 8px 22px 44px;
    }
    .pp__cta {
      margin-top: 32px;
    }
  }
</style>
