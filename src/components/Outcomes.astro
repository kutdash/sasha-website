---
import { OUTCOMES } from '../config';
---

<section id="outcomes" class="outcomes section">
  <div class="container">
    <p class="h-eyebrow reveal">результат курса</p>
    <h2 class="h-1 reveal">
      что ты <span class="outcomes__accent">получишь</span>
    </h2>

    <div class="outcomes__grid">
      {OUTCOMES.map((o, i) => (
        <article
          class:list={['outcome', i === 0 && 'outcome--wide']}
          style={`transition-delay: ${i * 70}ms`}
        >
          <p class="outcome__headline">{o.headline}</p>
          <h3 class="outcome__title">{o.title}</h3>
          <p class="outcome__desc">{o.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .outcomes .h-1 {
    margin-top: 12px;
    margin-bottom: 64px;
  }
  .outcomes__accent {
    color: var(--pink-deep);
  }

  .outcomes__grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 16px;
  }

  .outcome {
    grid-column: span 2;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 32px 28px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 6px;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .outcome:hover {
    border-color: var(--ink);
  }
  .outcome--wide {
    grid-column: span 3;
    background: var(--pink-soft);
    border-color: var(--pink-deep);
  }
  .outcomes__grid > .outcome:nth-child(2) {
    grid-column: span 3;
  }

  .outcome__headline {
    font-family: var(--font-sans);
    font-size: clamp(28px, 3.4vw, 48px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.035em;
    text-transform: lowercase;
    color: var(--pink-deep);
  }

  .outcome__title {
    font-family: var(--font-sans);
    font-size: clamp(18px, 1.5vw, 22px);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    text-transform: lowercase;
    color: var(--ink);
    padding-top: 16px;
    border-top: 1px solid var(--line);
  }

  .outcome__desc {
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-soft);
  }

  @media (max-width: 960px) {
    .outcomes__grid {
      grid-template-columns: 1fr 1fr;
    }
    .outcome,
    .outcome--wide,
    .outcomes__grid > .outcome:nth-child(2) {
      grid-column: auto;
    }
  }

  @media (max-width: 560px) {
    .outcomes__grid {
      grid-template-columns: 1fr;
    }
    .outcome {
      padding: 24px 20px;
    }
  }
</style>
