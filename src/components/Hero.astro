---
import Button from './Button.astro';
import { CHECKOUT, SITE } from '../config';
---

<section class="hero">
  <div class="container hero__inner">
    <div class="hero__top">
      <span class="brand name">Саша Буртасова</span>
      <nav class="nav">
        <a href="#about">обо мне</a>
        <a href="#program">программа</a>
        <a href="#cases">кейсы</a>
        <a href="#pricing">тарифы</a>
      </nav>
      <Button href="#pricing" variant="bracket" external={false}>мне надо</Button>
    </div>

    <div class="hero__main">
      <p class="hero__eyebrow">
        старт <span class="underline-pink">{SITE.startDate}</span> · {SITE.duration}
      </p>

      <h1 class="hero__title h-display">
        путь<br />
        видеографа
      </h1>

      <p class="hero__subtitle body-lg">
        с нуля до <span class="underline-pink">первых клиентов</span> и стабильного дохода.
        курс-сопровождение от <span class="name">Саши Буртасовой</span>.
      </p>

      <div class="hero__cta">
        <Button href="#pricing" variant="bracket" external={false}>выбрать тариф</Button>
        <div class="hero__timer" data-deadline={SITE.discountDeadlineIso} aria-label="До повышения цены">
          <p class="hero__timer-label">до повышения цены</p>
          <div class="hero__timer-row">
            <span class="hero__timer-cell"><span class="hero__timer-num" data-unit="days">--</span><span class="hero__timer-unit">дн</span></span>
            <span class="hero__timer-cell"><span class="hero__timer-num" data-unit="hours">--</span><span class="hero__timer-unit">ч</span></span>
            <span class="hero__timer-cell"><span class="hero__timer-num" data-unit="minutes">--</span><span class="hero__timer-unit">мин</span></span>
            <span class="hero__timer-cell"><span class="hero__timer-num" data-unit="seconds">--</span><span class="hero__timer-unit">сек</span></span>
          </div>
        </div>
      </div>
    </div>

    <div class="hero__media">
      <video class="hero__video" autoplay muted loop playsinline preload="auto" aria-hidden="true">
        <source src="/videos/hero.mp4" type="video/mp4" />
      </video>
      <video class="hero__video" autoplay muted loop playsinline preload="auto" aria-hidden="true">
        <source src="/videos/hero-3.mp4" type="video/mp4" />
      </video>
      <video class="hero__video" autoplay muted loop playsinline preload="auto" aria-hidden="true">
        <source src="/videos/hero-2.mp4" type="video/mp4" />
      </video>
    </div>

    <div class="hero__stats">
      <div class="stat">
        <span class="stat__num">15к → 850к ₽</span>
        <span class="stat__label">мой доход за 3 года</span>
      </div>
      <div class="stat">
        <span class="stat__num">214 → 20k</span>
        <span class="stat__label">набрала подписчиков в инсте за год*</span>
      </div>
      <div class="stat">
        <span class="stat__num">50+</span>
        <span class="stat__label">учеников на курсе</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding-top: 24px;
    padding-bottom: 80px;
    overflow: hidden;
  }
  .hero__inner {
    position: relative;
    z-index: 1;
  }
  .hero__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding: 16px 0 80px;
  }
  .brand {
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 800;
    letter-spacing: -0.02em;
  }
  .nav {
    display: flex;
    gap: 28px;
    font-size: 15px;
    font-weight: 500;
  }
  .nav a {
    color: var(--ink);
    transition: color 0.2s;
  }
  .nav a:hover {
    color: var(--pink-deep);
  }

  .hero__eyebrow {
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
    margin-bottom: 32px;
    letter-spacing: -0.01em;
  }

  .hero__title {
    margin: 0 0 32px;
  }
  .hero__subtitle {
    max-width: 640px;
    margin-bottom: 48px;
  }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 28px;
  }
  .hero__timer {
    display: flex;
    align-items: baseline;
    gap: 14px;
    padding-left: 28px;
    border-left: 1px solid var(--line);
  }
  .hero__timer-label {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-soft);
    letter-spacing: -0.01em;
  }
  .hero__timer-row {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .hero__timer-cell {
    display: flex;
    align-items: baseline;
    gap: 3px;
  }
  .hero__timer-num {
    font-family: var(--font-sans);
    font-size: 20px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
  }
  .hero__timer-unit {
    font-size: 11px;
    font-weight: 500;
    color: var(--ink-soft);
    letter-spacing: 0.02em;
  }
  .hero__timer.is-expired {
    display: none;
  }

  /* Lookbook collage — 3 equal vertical (9:16) video tiles */
  .hero__media {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 80px;
  }
  .hero__video {
    width: 100%;
    aspect-ratio: 9 / 16;
    object-fit: cover;
    border-radius: 4px;
    background: var(--bg-soft);
    display: block;
  }

  .hero__stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid var(--line);
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .stat__num {
    font-size: clamp(24px, 2.6vw, 36px);
    font-weight: 800;
    letter-spacing: -0.025em;
  }
  .stat__label {
    font-size: 14px;
    color: var(--ink-soft);
    letter-spacing: -0.01em;
  }

  @media (max-width: 760px) {
    .hero__top { padding-bottom: 40px; }
    .nav { display: none; }
    .hero__media {
      gap: 8px;
    }
    .hero__stats {
      grid-template-columns: 1fr;
      gap: 20px;
    }
    .hero__cta {
      gap: 20px;
    }
    .hero__timer {
      padding-left: 0;
      border-left: none;
    }
  }
</style>

<script>
  const timer = document.querySelector('.hero__timer') as HTMLElement | null;
  if (timer) {
    const deadline = new Date(timer.dataset.deadline || '').getTime();
    const nums: Record<string, HTMLElement | null> = {
      days: timer.querySelector('[data-unit="days"]'),
      hours: timer.querySelector('[data-unit="hours"]'),
      minutes: timer.querySelector('[data-unit="minutes"]'),
      seconds: timer.querySelector('[data-unit="seconds"]'),
    };
    const pad = (n: number) => String(n).padStart(2, '0');
    const tick = () => {
      const diff = deadline - Date.now();
      if (diff <= 0) {
        timer.classList.add('is-expired');
        return;
      }
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      if (nums.days) nums.days.textContent = String(days);
      if (nums.hours) nums.hours.textContent = pad(hours);
      if (nums.minutes) nums.minutes.textContent = pad(minutes);
      if (nums.seconds) nums.seconds.textContent = pad(seconds);
    };
    tick();
    setInterval(tick, 1000);
  }
</script>
