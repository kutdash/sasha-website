---
const vectors = [
  { num: '01', label: 'продвижение' },
  { num: '02', label: 'прокачка видеографии' },
];
---

<section id="approach" class="approach section">
  <div class="container">
    <p class="h-eyebrow reveal">мой подход</p>
    <h2 class="h-1 reveal">
      обучение строится <span class="approach__accent">под твои задачи</span>
    </h2>

    <ul class="approach__list">
      {vectors.map((v, i) => (
        <li class="approach__item reveal" style={`transition-delay: ${i * 80}ms`}>
          <span class="approach__index">{v.num}</span>
          <span class="approach__text">{v.label}</span>
        </li>
      ))}
    </ul>

    <p class="approach__note reveal">
      ты сама выбираешь акцент: фокус на одном из направлений или работа в обоих сразу
    </p>
  </div>
</section>

<style>
  .approach .h-1 {
    margin-top: 12px;
    margin-bottom: 56px;
    max-width: 18ch;
  }
  .approach__accent {
    color: var(--pink-deep);
  }
  .approach__list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0;
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
  }
  .approach__item {
    display: flex;
    gap: 24px;
    align-items: baseline;
    padding: 28px 12px;
  }
  .approach__item:first-child {
    border-right: 1px solid var(--line);
  }
  .approach__index {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-soft);
    letter-spacing: 0;
    flex-shrink: 0;
  }
  .approach__text {
    font-size: clamp(20px, 1.9vw, 28px);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }
  .approach__note {
    margin-top: 32px;
    font-size: clamp(14px, 1.05vw, 16px);
    line-height: 1.5;
    color: var(--ink-soft);
    max-width: 64ch;
  }
  @media (max-width: 720px) {
    .approach__list {
      grid-template-columns: 1fr;
    }
    .approach__item:first-child {
      border-right: none;
      border-bottom: 1px solid var(--line);
    }
    .approach__item {
      padding: 22px 8px;
      gap: 16px;
    }
  }
</style>
