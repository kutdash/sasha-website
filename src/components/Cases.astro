---
import { CASES } from '../config';

const handleSlug = (handle: string) => handle.replace(/^@/, '');
---

<section id="cases" class="cases section">
  <div class="container">
    <p class="h-eyebrow reveal">истории учениц</p>
    <h2 class="h-1 reveal">
      ушли с <span class="cases__accent">результатом</span>
    </h2>

    <div class="cases__grid">
      {CASES.map((c, i) => (
        <article class="case reveal" style={`transition-delay: ${i * 80}ms`}>
          <aside class="case__side">
            <a href={c.handleUrl} class="case__head" target="_blank" rel="noopener noreferrer">
              <img
                class="case__avatar"
                src={c.avatar ?? `https://unavatar.io/instagram/${handleSlug(c.handle)}`}
                alt={`Аватар ${c.name}`}
                loading="lazy"
                width="64"
                height="64"
              />
              <div class="case__id">
                <p class="case__name">{c.name}</p>
                <p class="case__handle">{c.handle} <span class="case__arrow">↗</span></p>
              </div>
            </a>
            <blockquote class="case__quote">«{c.quote}»</blockquote>
          </aside>

          <div class="case__main">
            <p class="case__hook">{c.hookStat}</p>

            <div class="case__cols">
              <div class="case__col">
                <p class="case__col-label">было</p>
                <ul>
                  {c.before.map((b) => <li>{b.toLowerCase()}</li>)}
                </ul>
              </div>
              <div class="case__col case__col--after">
                <p class="case__col-label">стало</p>
                <ul>
                  {c.after.map((a) => <li>{a.toLowerCase()}</li>)}
                </ul>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .cases .h-1 {
    margin-top: 12px;
    margin-bottom: 64px;
  }
  .cases__accent {
    color: var(--pink-deep);
  }

  .cases__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .case {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 48px;
    padding: 40px 36px;
    background: var(--bg);
    border: 1px solid var(--line);
    border-radius: 6px;
    transition: border-color 0.3s ease;
    align-items: start;
  }
  .case:hover {
    border-color: var(--ink);
  }

  .case__head {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    align-self: flex-start;
    transition: transform 0.25s ease;
  }
  .case__head:hover {
    transform: translateX(2px);
  }
  .case__head:hover .case__handle {
    color: var(--pink-deep);
  }
  .case__side {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .case__main {
    display: flex;
    flex-direction: column;
    gap: 28px;
    min-width: 0;
  }
  .case__avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--pink-soft);
    display: block;
  }
  .case__id {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .case__name {
    font-weight: 600;
    font-size: 17px;
    letter-spacing: -0.01em;
    text-transform: lowercase;
  }
  .case__handle {
    font-size: 13px;
    color: var(--ink-soft);
    transition: color 0.2s ease;
  }
  .case__arrow {
    display: inline-block;
    transition: transform 0.25s ease;
  }
  .case__head:hover .case__arrow {
    transform: translate(2px, -2px);
  }

  .case__hook {
    font-family: var(--font-sans);
    font-size: clamp(22px, 1.9vw, 28px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.025em;
    text-transform: lowercase;
    color: var(--pink-deep);
  }

  .case__cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .case__col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .case__col-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
  }
  .case__col ul {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .case__col li {
    font-size: 14px;
    line-height: 1.4;
    padding-left: 16px;
    position: relative;
  }
  .case__col li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 8px;
    height: 1px;
    background: var(--ink-soft);
  }
  .case__col--after li::before {
    background: var(--pink-deep);
  }

  .case__quote {
    font-family: var(--font-sans);
    font-size: clamp(17px, 1.4vw, 20px);
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.015em;
    color: var(--ink);
    text-transform: lowercase;
  }

  @media (max-width: 760px) {
    .case {
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 28px 22px;
    }
  }
</style>
