<section class="quote section">
  <div class="container">
    <blockquote class="quote__text reveal">
      большие изменения<br />
      начинаются с одного решения.
      <span class="quote__break"></span>
      возможно, это оно.<br />
      <span class="quote__accent">ты с нами?</span> 🤍
    </blockquote>
  </div>
</section>

<style>
  .quote {
    padding-top: 96px;
    padding-bottom: 96px;
  }
  .quote__text {
    font-family: var(--font-sans);
    font-size: clamp(32px, 4.5vw, 64px);
    font-weight: 600;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--ink);
    text-align: center;
    max-width: 26ch;
    margin: 0 auto;
    quotes: none;
  }
  .quote__text::before,
  .quote__text::after {
    content: '';
  }
  .quote__accent {
    color: var(--pink-deep);
    font-style: italic;
  }
  .quote__break {
    display: block;
    height: 0.6em;
  }

  @media (max-width: 720px) {
    .quote {
      padding-top: 64px;
      padding-bottom: 64px;
    }
  }
</style>
