---
import { TARIFFS, SITE, SOCIALS } from '../config';
---

<script is:inline define:vars={{ deadline: SITE.discountDeadlineIso }}>
  (() => {
    if (Date.now() <= new Date(deadline).getTime()) return;
    const apply = () => {
      document.querySelectorAll('[data-price-block], [data-cta-block], [data-installments]').forEach((block) => {
        const before = block.querySelector('[data-state="before"]');
        const after = block.querySelector('[data-state="after"]');
        if (before) before.hidden = true;
        if (after) after.hidden = false;
      });
      document.querySelectorAll('[data-pre-deadline]').forEach((el) => {
        el.style.display = 'none';
      });
      document.querySelectorAll('.pricing__timer, .hero__timer').forEach((el) => {
        el.classList.add('is-expired');
      });
    };
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', apply);
    } else {
      apply();
    }
  })();
</script>

<section id="pricing" class="pricing section">
  <div class="container">
    <p class="h-eyebrow reveal">тарифы</p>
    <h2 class="h-1 reveal">
      выбери свой <span class="pricing__accent">формат</span>
    </h2>
    <p class="pricing__intro reveal body-md" data-pre-deadline>
      специальные цены действуют до <span class="underline-pink">{SITE.discountEndDate}</span> включительно
    </p>

    <div class="pricing__timer reveal" data-deadline={SITE.discountDeadlineIso} aria-label="До повышения цены">
      <p class="pricing__timer-label">до повышения цены</p>
      <div class="pricing__timer-row">
        <span class="pricing__timer-num" data-unit="days">--</span>
        <span class="pricing__timer-colon">:</span>
        <span class="pricing__timer-num" data-unit="hours">--</span>
        <span class="pricing__timer-colon">:</span>
        <span class="pricing__timer-num" data-unit="minutes">--</span>
        <span class="pricing__timer-colon">:</span>
        <span class="pricing__timer-num" data-unit="seconds">--</span>
      </div>
      <div class="pricing__timer-units">
        <span>дни</span>
        <span>часы</span>
        <span>минуты</span>
        <span>секунды</span>
      </div>
    </div>

    <p class="pricing__callout reveal">
      все тарифы включают личную обратную связь от саши 🔥
    </p>

    <div class="pricing__grid">
      {TARIFFS.map((t, i) => (
        <article
          class:list={[
            'tariff',
            t.highlighted && 'tariff--hl',
            t.dark && 'tariff--dark',
            t.sold && 'tariff--sold',
          ]}
          style={`transition-delay: ${i * 80}ms`}
        >
          <header class="tariff__head">
            <div class="tariff__top">
              <h3 class="tariff__name">{t.name.toLowerCase()}</h3>
              {t.chip && !t.sold && <span class="tariff__chip">{t.chip}</span>}
              {t.sold && <span class="tariff__chip tariff__chip--sold">sold out</span>}
            </div>
            {t.seats && <p class="tariff__seats">{t.seats}</p>}
            <p class="tariff__tagline">{t.tagline.toLowerCase()}</p>
          </header>

          <div class="tariff__price" data-price-block>
            <div class="tariff__price-state" data-state="before">
              {t.oldPrice && <span class="tariff__old">{t.oldPrice}</span>}
              <span class="tariff__now">{t.price}</span>
              <span class="tariff__usd">/ {t.priceUsd}</span>
            </div>
            <div class="tariff__price-state" data-state="after" hidden>
              <span class="tariff__now">{t.oldPrice || t.price}</span>
              <span class="tariff__usd">/ {t.oldPriceUsd || t.priceUsd}</span>
            </div>
          </div>

          <ul class="tariff__features">
            {t.features.map((f) => (
              <li>{f.toLowerCase()}</li>
            ))}
          </ul>

          {t.note && <p class="tariff__note">* {t.note.toLowerCase()}</p>}

          <a
            href={t.checkout}
            class:list={['tariff__btn', t.highlighted && 'tariff__btn--hl']}
            target={t.checkout.startsWith('http') ? '_blank' : undefined}
            rel={t.checkout.startsWith('http') ? 'noopener noreferrer' : undefined}
            data-cta-block
          >
            <span data-state="before">{t.cta.toLowerCase()}</span>
            <span data-state="after" hidden>{(t.ctaAfter || t.cta).toLowerCase()}</span>
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
              <path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </article>
      ))}
    </div>

    <p class="pricing__installments reveal muted">
      доступна рассрочка на 6 и 12 месяцев · от 3 299 ₽/мес · все проценты беру на себя
    </p>

    <div class="pricing__contact reveal">
      <p class="pricing__contact-text">
        если остались вопросы – пиши, всё решим 💗
      </p>
      <a
        href={SOCIALS.telegram}
        class="pricing__contact-btn"
        target="_blank"
        rel="noopener noreferrer"
      >
        написать мне в тг
        <svg width="20" height="20" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .pricing .h-1 {
    margin-top: 12px;
    margin-bottom: 16px;
  }
  .pricing__accent {
    color: var(--pink-deep);
  }
  .pricing__intro {
    margin-bottom: 16px;
    color: var(--ink-soft);
  }

  .pricing__timer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    margin-bottom: 44px;
    padding: 8px 0;
    text-align: center;
  }
  .pricing__timer-label {
    font-family: var(--font-sans);
    font-size: clamp(16px, 1.3vw, 19px);
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .pricing__timer-row {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr;
    align-items: baseline;
    gap: 10px;
    max-width: 560px;
    width: 100%;
  }
  .pricing__timer-num {
    font-family: var(--font-sans);
    font-size: clamp(44px, 6vw, 72px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    text-align: center;
  }
  .pricing__timer-colon {
    font-family: var(--font-sans);
    font-size: clamp(32px, 4.5vw, 52px);
    font-weight: 400;
    line-height: 1;
    color: var(--ink-soft);
    opacity: 0.4;
  }
  .pricing__timer-units {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr 1fr;
    gap: 10px;
    max-width: 560px;
    width: 100%;
    margin-top: 2px;
  }
  .pricing__timer-units span {
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-soft);
    letter-spacing: 0.02em;
    text-align: center;
  }
  .pricing__timer.is-expired {
    display: none;
  }

  .pricing__callout {
    display: inline-flex;
    align-items: center;
    margin-bottom: 56px;
    padding: 10px 18px;
    background: var(--pink-soft);
    border: 1px solid var(--pink-deep);
    border-radius: 999px;
    font-size: 14px;
    line-height: 1.3;
    font-weight: 500;
    color: var(--ink);
  }

  .pricing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .tariff {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 32px 28px;
    border: 1px solid var(--line);
    background: var(--bg);
    border-radius: 6px;
    transition: border-color 0.3s ease, transform 0.3s ease;
  }
  .tariff:hover {
    border-color: var(--ink);
  }
  .tariff--hl {
    background: var(--pink-soft);
    border-color: var(--pink-deep);
  }
  .tariff--dark {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }
  .tariff--dark .tariff__head {
    border-bottom-color: rgba(246, 244, 236, 0.2);
  }
  .tariff--dark .tariff__seats,
  .tariff--dark .tariff__usd,
  .tariff--dark .tariff__old,
  .tariff--dark .tariff__note {
    color: rgba(246, 244, 236, 0.55);
  }
  .tariff--dark .tariff__chip {
    background: var(--bg);
    color: var(--ink);
  }
  .tariff--dark .tariff__features li::before {
    background: var(--bg);
  }
  .tariff--dark .tariff__btn {
    background: var(--bg);
    color: var(--ink);
  }
  .tariff--dark .tariff__btn:hover {
    background: var(--pink-deep);
    color: var(--bg);
  }
  .tariff--sold {
    opacity: 0.65;
  }

  .tariff__head {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--line);
  }
  .tariff__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .tariff__name {
    font-family: var(--font-sans);
    font-size: clamp(28px, 2.6vw, 36px);
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    text-transform: lowercase;
  }
  .tariff__chip {
    padding: 4px 10px;
    background: var(--pink-deep);
    color: var(--bg);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    border-radius: 999px;
    white-space: nowrap;
  }
  .tariff__chip--sold {
    background: var(--ink);
  }
  .tariff__seats {
    font-size: 13px;
    color: var(--ink-soft);
    letter-spacing: 0;
  }
  .tariff__tagline {
    font-size: 15px;
    line-height: 1.4;
    color: var(--ink);
  }

  .tariff__price {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 8px;
  }
  .tariff__old {
    font-size: 16px;
    color: var(--ink-soft);
    text-decoration: line-through;
  }
  .tariff__now {
    font-size: clamp(28px, 2.6vw, 36px);
    font-weight: 700;
    letter-spacing: -0.025em;
  }
  .tariff__usd {
    font-size: 14px;
    color: var(--ink-soft);
  }

  .tariff__features {
    display: flex;
    flex-direction: column;
    gap: 10px;
    flex: 1;
  }
  .tariff__features li {
    font-size: 14px;
    line-height: 1.4;
    padding-left: 22px;
    position: relative;
  }
  .tariff__features li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 8px;
    width: 12px;
    height: 1px;
    background: var(--pink-deep);
  }

  .tariff__note {
    font-size: 11px;
    line-height: 1.4;
    color: var(--ink-soft);
  }

  .tariff__btn {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 16px 24px;
    background: var(--ink);
    color: var(--bg);
    border-radius: 999px;
    font-weight: 600;
    font-size: 15px;
    letter-spacing: -0.01em;
    text-transform: lowercase;
    transition: background 0.25s ease, transform 0.25s ease;
    margin-top: auto;
  }
  .tariff__btn svg {
    transition: transform 0.25s ease;
  }
  .tariff__btn:hover {
    background: var(--pink-deep);
    transform: translateY(-2px);
  }
  .tariff__btn:hover svg {
    transform: translateX(3px);
  }
  .tariff__btn--hl {
    background: var(--ink);
  }
  .tariff__btn--hl:hover {
    background: var(--pink-deeper);
  }

  .pricing__installments {
    margin-top: 32px;
    text-align: center;
    font-size: 14px;
  }

  .pricing__contact {
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 18px;
    text-align: center;
  }
  .pricing__contact-text {
    font-family: var(--font-sans);
    font-size: clamp(16px, 1.3vw, 19px);
    font-weight: 500;
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .pricing__contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 20px 38px;
    background: var(--pink-soft);
    color: var(--pink-deep);
    border: 2px solid var(--pink-deep);
    border-radius: 999px;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: clamp(17px, 1.5vw, 20px);
    letter-spacing: -0.01em;
    text-transform: lowercase;
    transition: background 0.25s ease, color 0.25s ease, transform 0.25s ease;
    will-change: transform;
  }
  .pricing__contact-btn:hover {
    background: var(--pink-deep);
    color: var(--bg);
    transform: translateY(-2px);
  }
  .pricing__contact-btn svg {
    transition: transform 0.25s ease;
  }
  .pricing__contact-btn:hover svg {
    transform: translateX(4px);
  }

  @media (max-width: 960px) {
    .pricing__grid {
      grid-template-columns: 1fr;
    }
    .pricing__timer-row {
      gap: 6px;
    }
    .pricing__timer-num {
      font-size: 42px;
    }
    .pricing__timer-colon {
      font-size: 30px;
    }
    .pricing__timer-units span {
      font-size: 11px;
    }
  }
</style>

<script>
  const timer = document.querySelector('.pricing__timer') as HTMLElement | null;
  if (timer) {
    const deadline = new Date(timer.dataset.deadline || '').getTime();
    const nums: Record<string, HTMLElement | null> = {
      days: timer.querySelector('[data-unit="days"]'),
      hours: timer.querySelector('[data-unit="hours"]'),
      minutes: timer.querySelector('[data-unit="minutes"]'),
      seconds: timer.querySelector('[data-unit="seconds"]'),
    };
    const pad = (n: number) => String(n).padStart(2, '0');
    const tick = () => {
      const diff = deadline - Date.now();
      if (diff <= 0) {
        timer.classList.add('is-expired');
        return;
      }
      const days = Math.floor(diff / 86400000);
      const hours = Math.floor((diff % 86400000) / 3600000);
      const minutes = Math.floor((diff % 3600000) / 60000);
      const seconds = Math.floor((diff % 60000) / 1000);
      if (nums.days) nums.days.textContent = String(days);
      if (nums.hours) nums.hours.textContent = pad(hours);
      if (nums.minutes) nums.minutes.textContent = pad(minutes);
      if (nums.seconds) nums.seconds.textContent = pad(seconds);
    };
    tick();
    setInterval(tick, 1000);
  }
</script>
