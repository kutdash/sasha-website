---
interface Props {
  href: string;
  variant?: 'primary' | 'ghost' | 'pink' | 'bracket';
  external?: boolean;
  class?: string;
}

const { href, variant = 'bracket', external = true, class: className = '' } = Astro.props;
const target = external && href.startsWith('http') ? '_blank' : undefined;
const rel = target ? 'noopener noreferrer' : undefined;
---

{variant === 'bracket' ? (
  <a href={href} class:list={['btn-bracket', className]} target={target} rel={rel}>
    <span class="btn-bracket__b">[</span>
    <span class="btn-bracket__l"><slot /></span>
    <span class="btn-bracket__b">]</span>
  </a>
) : (
  <a href={href} class:list={['btn', `btn--${variant}`, className]} target={target} rel={rel}>
    <span><slot /></span>
    <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
      <path d="M3 9h12M11 5l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </a>
)}

<style>
  /* Bracket CTA — clean [ text ], no underline, hover turns pink */
  .btn-bracket {
    display: inline-flex;
    align-items: baseline;
    gap: 6px;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: clamp(16px, 1.4vw, 18px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-transform: lowercase;
    transition: color 0.2s ease;
  }
  .btn-bracket:hover,
  .btn-bracket:hover .btn-bracket__b {
    color: var(--pink-deep);
  }
  .btn-bracket__b {
    font-weight: 400;
    color: var(--ink);
    transition: color 0.2s ease;
  }

  /* Standard rounded buttons (kept for nav / secondary CTAs if needed) */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 14px 24px;
    border-radius: 999px;
    font-weight: 600;
    font-size: 14px;
    letter-spacing: -0.01em;
    transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
    will-change: transform;
    border: 1px solid transparent;
    line-height: 1;
    text-transform: lowercase;
  }
  .btn:hover {
    transform: translateY(-2px);
  }
  .btn svg {
    transition: transform 0.25s ease;
  }
  .btn:hover svg {
    transform: translateX(3px);
  }

  .btn--primary {
    background: var(--ink);
    color: var(--bg);
  }
  .btn--primary:hover {
    background: var(--pink-deep);
  }

  .btn--pink {
    background: var(--pink);
    color: var(--ink);
  }
  .btn--pink:hover {
    background: var(--pink-deep);
    color: var(--bg);
  }

  .btn--ghost {
    background: transparent;
    color: var(--ink);
    border-color: var(--ink);
  }
  .btn--ghost:hover {
    background: var(--ink);
    color: var(--bg);
  }
</style>
