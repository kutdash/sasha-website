---
import { STUDENT_WORKS } from '../config';
---

<section id="student-works" class="works section">
  <div class="container">
    <p class="h-eyebrow reveal">работы учеников</p>
    <h2 class="h-1 reveal">
      что снимают <span class="works__accent">мои ученики</span>
    </h2>
    <p class="works__lead reveal body-md">
      fashion, свадьбы, backstage, beauty — каждый нашёл свой стиль и снимает то, что любит
    </p>
  </div>

  <div class="works__strip">
    {STUDENT_WORKS.map((w, i) => (
      w.type === 'video' ? (
        <button
          type="button"
          class="work reveal"
          data-video-card
          aria-label="Включить звук"
          style={`transition-delay: ${i * 60}ms`}
        >
          <video
            class="work__video"
            src={w.src}
            autoplay
            muted
            loop
            playsinline
            preload="metadata"
            aria-hidden="true"
          ></video>
          <span class="work__sound" aria-hidden="true">
            <svg class="work__sound-icon work__sound-icon--off" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.17v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>
            </svg>
            <svg class="work__sound-icon work__sound-icon--on" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02zM14 3.23v2.06c2.89.86 5 3.54 5 6.71s-2.11 5.85-5 6.71v2.06c4.01-.91 7-4.49 7-8.77s-2.99-7.86-7-8.77z"/>
            </svg>
          </span>
        </button>
      ) : (
        <a
          href={w.url}
          class="work reveal"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Открыть в Instagram"
          style={`transition-delay: ${i * 60}ms`}
        >
          <img class="work__cover" src={w.cover} alt="Работа ученика" loading="lazy" />
          <span class="work__play" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z" />
            </svg>
          </span>
        </a>
      )
    ))}
  </div>
</section>

<style>
  .works {
    overflow: hidden;
  }
  .works .h-1 {
    margin-top: 12px;
    margin-bottom: 24px;
  }
  .works__accent {
    color: var(--pink-deep);
  }
  .works__lead {
    max-width: 640px;
    color: var(--ink-soft);
    margin-bottom: 48px;
  }

  .works__strip {
    display: flex;
    gap: 12px;
    padding: 0 clamp(20px, 5vw, 64px) 16px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    cursor: grab;
  }
  .works__strip:active {
    cursor: grabbing;
  }
  .works__strip::-webkit-scrollbar {
    height: 6px;
  }
  .works__strip::-webkit-scrollbar-track {
    background: transparent;
  }
  .works__strip::-webkit-scrollbar-thumb {
    background: var(--line);
    border-radius: 999px;
  }
  .works__strip::-webkit-scrollbar-thumb:hover {
    background: var(--ink-soft);
  }

  .work {
    position: relative;
    flex: 0 0 calc((100% - 32px) / 3);
    min-width: 280px;
    aspect-ratio: 9 / 16;
    border-radius: 6px;
    overflow: hidden;
    background: var(--bg-soft);
    border: none;
    padding: 0;
    cursor: pointer;
    scroll-snap-align: start;
    transition: transform 0.3s ease;
  }
  .work:hover {
    transform: translateY(-4px);
  }

  .work__video,
  .work__cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .work__sound {
    position: absolute;
    bottom: 10px;
    right: 10px;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.55);
    color: #fff;
    display: grid;
    place-items: center;
    backdrop-filter: blur(8px);
    transition: background 0.25s ease;
  }
  .work:hover .work__sound {
    background: rgba(0, 0, 0, 0.75);
  }
  .work__sound-icon {
    grid-area: 1 / 1;
    transition: opacity 0.2s ease;
  }
  .work__sound-icon--on {
    opacity: 0;
  }
  .work.is-unmuted .work__sound-icon--off {
    opacity: 0;
  }
  .work.is-unmuted .work__sound-icon--on {
    opacity: 1;
  }
  .work.is-unmuted .work__sound {
    background: var(--pink-deep);
  }

  .work__play {
    position: absolute;
    bottom: 10px;
    right: 10px;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    color: var(--ink);
    display: grid;
    place-items: center;
    transition: background 0.25s ease, color 0.25s ease;
  }
  .work__play svg {
    margin-left: 2px;
  }
  .work:hover .work__play {
    background: var(--pink-deep);
    color: var(--bg);
  }

  @media (max-width: 720px) {
    .works__strip {
      padding: 0 16px;
      gap: 8px;
    }
    .work {
      min-width: 140px;
      flex: 0 0 38vw;
    }
  }
</style>

<script>
  const cards = document.querySelectorAll<HTMLButtonElement>('[data-video-card]');
  cards.forEach((card) => {
    const video = card.querySelector('video');
    if (!video) return;
    card.addEventListener('click', (e) => {
      // ignore click after drag scroll
      if (card.dataset.justDragged === '1') {
        card.dataset.justDragged = '0';
        e.preventDefault();
        return;
      }
      if (video.muted) {
        cards.forEach((other) => {
          if (other === card) return;
          const otherVideo = other.querySelector('video');
          if (otherVideo && !otherVideo.muted) {
            otherVideo.muted = true;
            other.classList.remove('is-unmuted');
            other.setAttribute('aria-label', 'Включить звук');
          }
        });
        video.muted = false;
        video.volume = 1;
        card.classList.add('is-unmuted');
        card.setAttribute('aria-label', 'Выключить звук');
      } else {
        video.muted = true;
        card.classList.remove('is-unmuted');
        card.setAttribute('aria-label', 'Включить звук');
      }
    });
  });

  // IntersectionObserver — pause videos that aren't visible to save CPU/bandwidth
  const allVideos = document.querySelectorAll<HTMLVideoElement>('[data-video-card] video');
  if ('IntersectionObserver' in window && allVideos.length) {
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        const video = entry.target as HTMLVideoElement;
        if (entry.isIntersecting) {
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    }, { threshold: 0.25 });
    allVideos.forEach((v) => io.observe(v));
  }

  // Drag-to-scroll for mouse users
  const strip = document.querySelector<HTMLDivElement>('.works__strip');
  if (strip) {
    let isDown = false;
    let startX = 0;
    let scrollLeftStart = 0;
    let moved = false;
    strip.addEventListener('mousedown', (e) => {
      isDown = true;
      moved = false;
      startX = e.pageX - strip.offsetLeft;
      scrollLeftStart = strip.scrollLeft;
    });
    strip.addEventListener('mouseleave', () => { isDown = false; });
    strip.addEventListener('mouseup', (e) => {
      isDown = false;
      if (moved) {
        const target = (e.target as HTMLElement)?.closest('[data-video-card]') as HTMLElement | null;
        if (target) target.dataset.justDragged = '1';
      }
    });
    strip.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      const x = e.pageX - strip.offsetLeft;
      const walk = x - startX;
      if (Math.abs(walk) > 4) moved = true;
      strip.scrollLeft = scrollLeftStart - walk;
    });
  }
</script>
